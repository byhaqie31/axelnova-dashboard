# syntax=docker/dockerfile:1.7
FROM node:22-alpine

WORKDIR /app

ENV NODE_ENV=development
ENV HOST=0.0.0.0
ENV PORT=3000
ENV NUXT_TELEMETRY_DISABLED=1
# Force chokidar polling — needed for reliable HMR on macOS bind mounts
ENV CHOKIDAR_USEPOLLING=true
ENV CHOKIDAR_INTERVAL=400

COPY package*.json ./
RUN --mount=type=cache,target=/root/.npm npm ci

COPY . .

EXPOSE 3000 24678

CMD ["npm", "run", "dev"]
