# Production .env template for axelnova-dashboard frontend.
#
# On VPS:
#   cp frontend/.env.production.example frontend/.env.production
#   vim frontend/.env.production
#   # then fill in placeholders marked <FILL_IN>

# Public site URL — used by Nuxt for SSR canonical / OG / sitemap
NUXT_PUBLIC_SITE_URL=https://dashboard.axelnova.tech

# Browser-side base URL for backend API calls. Same-origin in prod
# (Caddy/Nginx on the VPS proxies /api/* to 127.0.0.1:8003).
NUXT_PUBLIC_API_BASE=https://dashboard.axelnova.tech

# Server runtime — these are also set in docker-compose.prod.yml; included here so
# `npm run build` / `node .output/server/index.mjs` work outside compose too.
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
NUXT_TELEMETRY_DISABLED=1
