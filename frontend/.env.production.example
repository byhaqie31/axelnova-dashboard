# Production .env template for axelnova-dashboard frontend.
#
# On VPS:
#   cp frontend/.env.production.example frontend/.env.production
#   vim frontend/.env.production

# Browser-side base URL for backend API calls. Same-origin in prod
# (Caddy/Nginx on the VPS proxies /api/* to 127.0.0.1:8003).
NUXT_PUBLIC_API_BASE=https://admin.axelnovaventures.com
