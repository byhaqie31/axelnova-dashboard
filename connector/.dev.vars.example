# Copy to connector/.dev.vars for `wrangler dev` (gitignored). In production these
# are set with `npx wrangler secret put <NAME>` instead — never commit real values.

# Laravel API origin (no trailing /api). The Worker calls ${API_BASE}/api/v1/connector/*.
API_BASE=http://host.docker.internal:8003

# Scoped connector token from: php artisan connector:token
CONNECTOR_TOKEN=paste-the-mcp-connector-token-here

# OAuth login gate (single-user, static credential check).
ACCESS_USERNAME=founder
ACCESS_PASSWORD=choose-a-strong-passphrase
