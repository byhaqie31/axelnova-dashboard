# ── Frontend (Nuxt) ──────────────────────────────────────────
frontend/.output
frontend/.data
frontend/.nuxt
frontend/.nitro
frontend/.cache
frontend/dist
frontend/node_modules
frontend/.env
frontend/.env.*
!frontend/.env.example
!frontend/.env.production.example

# ── Backend (Laravel) ────────────────────────────────────────
# storage/ and bootstrap/cache contents are ignored by committed .gitignore
# keepers INSIDE each dir — the empty skeleton must exist in fresh checkouts
# (CI, new clones) or `artisan package:discover` fails on composer install.
backend/vendor
backend/.env
backend/.env.*
!backend/.env.example
!backend/.env.production.example

# ── Logs ─────────────────────────────────────────────────────
/logs
*.log

# ── Editor ───────────────────────────────────────────────────
.fleet
.idea
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# ── Misc ─────────────────────────────────────────────────────
.DS_Store

# ── Claude Code ──────────────────────────────────────────────
.claude/settings.local.json
