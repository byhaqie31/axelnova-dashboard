<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <!-- Test-only key so the suite runs without a .env (CI). Never used outside tests. -->
        <env name="APP_KEY" value="base64:4uCrOYJfYHOxPlt/qeMcg0sN3aO5Gdkr3NnT0LoIRU0="/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <!-- Migrations use MySQL-dialect SQL (ENUM / MODIFY / FK toggles), so tests run
             against a real MySQL database — never SQLite. force="true" pins the database
             name so RefreshDatabase can never wipe the dev database. DB host/credentials
             come from .env (local container) or exported env vars (CI). -->
        <env name="DB_CONNECTION" value="mysql"/>
        <env name="DB_DATABASE" value="axelnova_dashboard_test" force="true"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
    </php>
</phpunit>
