# syntax=docker/dockerfile:1.7
FROM php:8.4-cli-alpine

RUN apk add --no-cache \
        bash \
        git \
        unzip \
        zip \
        libzip-dev \
        icu-dev \
        oniguruma-dev \
        libpng-dev \
        libjpeg-turbo-dev \
        freetype-dev \
        $PHPIZE_DEPS \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install -j$(nproc) \
        bcmath \
        intl \
        pdo_mysql \
        zip \
        gd \
        opcache \
    && apk del $PHPIZE_DEPS

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /app

# First-boot bootstrap: copy .env, install vendor, ensure Laravel runtime dirs, generate APP_KEY.
# Runs every container start but is idempotent — fast no-op once the host bind mount is populated.
COPY <<'EOF' /usr/local/bin/dev-entrypoint.sh
#!/bin/sh
set -e
cd /app
[ ! -f .env ] && [ -f .env.example ] && cp .env.example .env
mkdir -p bootstrap/cache \
         storage/app/public \
         storage/framework/cache/data \
         storage/framework/sessions \
         storage/framework/testing \
         storage/framework/views \
         storage/logs
[ ! -f vendor/autoload.php ] && composer install --no-interaction --prefer-dist
grep -q '^APP_KEY=base64:' .env || php artisan key:generate --force
exec "$@"
EOF
RUN chmod +x /usr/local/bin/dev-entrypoint.sh

EXPOSE 8003

ENTRYPOINT ["/usr/local/bin/dev-entrypoint.sh"]
CMD ["php", "artisan", "serve", "--host=0.0.0.0", "--port=8003"]
