APP_NAME="Axel Nova Ventures"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8003

APP_TIMEZONE=Asia/Kuala_Lumpur

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
# When running Laravel inside the docker compose stack, host is `mysql`
# (the service from axelnova-infra). Use 127.0.0.1 if running natively.
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=axelnova_dashboard_db
DB_USERNAME=axelnova_dashboard_user
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Mailtrap recommended for local dev. Replace with prod SMTP (Mailgun/Postmark/SES) later.
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="baihaqie@axelnova.tech"
MAIL_FROM_NAME="Axel Nova Ventures"

ADMIN_NOTIFICATION_EMAIL=baihaqie@axelnova.tech
ADMIN_NAME="Ahmad Baihaqie"
ADMIN_CALENDLY_URL=https://calendly.com/baihaqie

# Admin portal login — consumed by AdminUserSeeder.
# Run: php artisan db:seed --class=AdminUserSeeder
ADMIN_LOGIN_EMAIL=baihaqie@axelnova.tech
ADMIN_LOGIN_PASSWORD=change-me

# The app origin (also the admin cockpit's origin + the CORS anchor).
FRONTEND_URL=http://localhost:3003
# The PUBLIC marketing site where clients/partners/teammates land — used for the
# referral link, client quote-PDF links, and partner/team login emails. Set this
# when the admin cockpit runs on its own subdomain (e.g. FRONTEND_URL=
# https://admin.example.com, PUBLIC_SITE_URL=https://example.com). Falls back to
# FRONTEND_URL when unset, so single-domain setups need nothing here.
PUBLIC_SITE_URL=http://localhost:3003

# Threads API (Meta app: Axel Nova Marketing Dashboard)
# ID/secret: developers.facebook.com -> app -> Use cases -> Access the Threads API -> Settings
# Token: same page -> User Token Generator (long-lived, 60 days; auto-refreshed once the scheduler command lands)
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=
