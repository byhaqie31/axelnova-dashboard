# Git / CI
.git
.gitignore
.github

# Local env (never bake secrets into the image — set via compose at runtime)
.env
.env.*
!.env.example

# Build artifacts that the vendor stage will regenerate
vendor
node_modules

# Local-only state
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*

# Tests + dev configs
tests
phpunit.xml
.phpunit.cache

# Dev-only Dockerfile
Dockerfile.dev

# Editor / OS
.idea
.vscode
.DS_Store
