# Production .env template for axelnova-dashboard backend.
#
# On VPS:
#   cp backend/.env.production.example backend/.env.production
#   vim backend/.env.production
#   # then fill in placeholders marked <FILL_IN>
#
# To generate APP_KEY (do this once, paste below):
#   docker run --rm axelnova-backend:latest php artisan key:generate --show

APP_NAME="Axel Nova Platform"
APP_ENV=production
APP_KEY=<FILL_IN>
APP_DEBUG=false
APP_URL=https://admin.axelnovaventures.com

APP_TIMEZONE=Asia/Kuala_Lumpur

LOG_CHANNEL=stack
LOG_LEVEL=info

# DB_HOST is set via docker-compose.prod.yml (resolves to the shared MySQL service).
# Do not set DB_HOST here — compose env wins, but keeping it absent avoids drift.
DB_CONNECTION=mysql
DB_PORT=3306
DB_DATABASE=axelnova_dashboard_db
DB_USERNAME=axelnova_dashboard_user
DB_PASSWORD=<FILL_IN>

BROADCAST_CONNECTION=log
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Hostinger SMTP. If 587/tls is blocked on the VPS, switch to MAIL_PORT=465 + MAIL_ENCRYPTION=ssl.
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@axelnova.tech
MAIL_PASSWORD=<FILL_IN>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@axelnova.tech"
MAIL_FROM_NAME="Axel Nova Ventures"

ADMIN_NOTIFICATION_EMAIL=baihaqie@axelnova.tech
ADMIN_NAME="Ahmad Baihaqie"
ADMIN_CALENDLY_URL=https://calendly.com/baihaqie

FRONTEND_URL=https://admin.axelnovaventures.com
